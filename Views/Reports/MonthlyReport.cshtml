@{
    ViewData["Title"] = "Monthly Report";
    var trips = ViewBag.Trips as List<FleetFlow.Models.Trip>;
    var fuelLogs = ViewBag.FuelLogs as List<FleetFlow.Models.FuelLog>;
    var maintenanceLogs = ViewBag.MaintenanceLogs as List<FleetFlow.Models.MaintenanceLog>;
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
                <li class="breadcrumb-item active">Monthly Report</li>
            </ol>
        </nav>
        <h4 class="mb-0"><i class="bi bi-calendar-month"></i> Monthly Report: @ViewBag.MonthName</h4>
    </div>
</div>

<!-- Month Selector -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" asp-action="MonthlyReport" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Year</label>
                <select name="year" class="form-select">
                    @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                    {
                        <option value="@y" selected="@(ViewBag.Year == y)">@y</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Month</label>
                <select name="month" class="form-select">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(ViewBag.Month == m)">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Generate Report
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h6 class="opacity-75">Completed Trips</h6>
                <h3>@trips?.Count</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h6 class="opacity-75">Revenue</h6>
                <h3>₹@ViewBag.TotalRevenue.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body">
                <h6 class="opacity-75">Fuel Cost</h6>
                <h3>₹@ViewBag.TotalFuelCost.ToString("N2")</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark">
            <div class="card-body">
                <h6 class="opacity-75">Maintenance Cost</h6>
                <h3>₹@ViewBag.TotalMaintenanceCost.ToString("N2")</h3>
            </div>
        </div>
    </div>
</div>

<!-- Detailed Tables -->
<div class="row g-4">
    <!-- Trips -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-geo-alt"></i> Completed Trips</h5>
            </div>
            <div class="card-body p-0">
                @if (trips != null && trips.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Trip Code</th>
                                    <th>Vehicle</th>
                                    <th>Driver</th>
                                    <th>Completed Date</th>
                                    <th>Distance</th>
                                    <th>Revenue</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var trip in trips)
                                {
                                    <tr>
                                        <td><code>@trip.TripCode</code></td>
                                        <td>@trip.Vehicle?.Name</td>
                                        <td>@trip.Driver?.Name</td>
                                        <td>@trip.CompletedAt?.ToString("dd MMM yyyy")</td>
                                        <td>@trip.DistanceTraveled?.ToString("N0") km</td>
                                        <td>₹@(trip.Revenue?.ToString("N2") ?? "0.00")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        No completed trips this month
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Reports
    </a>
</div>

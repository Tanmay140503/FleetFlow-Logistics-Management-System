@model IEnumerable<FleetFlow.ViewModels.VehicleReportViewModel>
@{
    ViewData["Title"] = "Vehicle Performance Report";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
                <li class="breadcrumb-item active">Vehicle Performance</li>
            </ol>
        </nav>
        <h4 class="mb-0"><i class="bi bi-truck"></i> Vehicle Performance Report</h4>
    </div>
    <a asp-action="ExportVehicleReport" class="btn btn-success">
        <i class="bi bi-file-earmark-excel"></i> Export to Excel
    </a>
</div>

<!-- Report Table -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Vehicle</th>
                        <th>License Plate</th>
                        <th>Total Trips</th>
                        <th>Distance (km)</th>
                        <th>Fuel Cost</th>
                        <th>Maintenance</th>
                        <th>Revenue</th>
                        <th>Net Profit</th>
                        <th>Fuel Efficiency</th>
                        <th>ROI (%)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var netProfit = item.TotalRevenue - item.TotalFuelCost - item.TotalMaintenanceCost;
                        <tr>
                            <td><strong>@item.VehicleName</strong></td>
                            <td><code>@item.LicensePlate</code></td>
                            <td><span class="badge bg-primary">@item.TotalTrips</span></td>
                            <td>@item.TotalDistance.ToString("N0")</td>
                            <td class="text-danger">$@item.TotalFuelCost.ToString("N2")</td>
                            <td class="text-warning">$@item.TotalMaintenanceCost.ToString("N2")</td>
                            <td class="text-success">$@item.TotalRevenue.ToString("N2")</td>
                            <td class="@(netProfit >= 0 ? "text-success" : "text-danger")">
                                <strong>$@netProfit.ToString("N2")</strong>
                            </td>
                            <td>
                                @if (item.FuelEfficiency > 0)
                                {
                                    <span>@item.FuelEfficiency.ToString("N2") km/L</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.ROI != 0)
                                {
                                    <span class="badge @(item.ROI >= 0 ? "bg-success" : "bg-danger")">
                                        @item.ROI.ToString("N1")%
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-secondary">
                    <tr>
                        <td colspan="2"><strong>TOTAL</strong></td>
                        <td><strong>@Model.Sum(v => v.TotalTrips)</strong></td>
                        <td><strong>@Model.Sum(v => v.TotalDistance).ToString("N0")</strong></td>
                        <td class="text-danger"><strong>$@Model.Sum(v => v.TotalFuelCost).ToString("N2")</strong></td>
                        <td class="text-warning"><strong>$@Model.Sum(v => v.TotalMaintenanceCost).ToString("N2")</strong></td>
                        <td class="text-success"><strong>$@Model.Sum(v => v.TotalRevenue).ToString("N2")</strong></td>
                        <td>
                            @{
                                var totalNet = Model.Sum(v => v.TotalRevenue) - Model.Sum(v => v.TotalFuelCost) - Model.Sum(v => v.TotalMaintenanceCost);
                            }
                            <strong class="@(totalNet >= 0 ? "text-success" : "text-danger")">
                                $@totalNet.ToString("N2")
                            </strong>
                        </td>
                        <td colspan="2"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Reports
    </a>
</div>

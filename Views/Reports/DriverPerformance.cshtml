@model IEnumerable<FleetFlow.ViewModels.DriverPerformanceViewModel>
@{
    ViewData["Title"] = "Driver Performance Report";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
                <li class="breadcrumb-item active">Driver Performance</li>
            </ol>
        </nav>
        <h4 class="mb-0"><i class="bi bi-person-badge"></i> Driver Performance Report</h4>
    </div>
    <a asp-action="ExportDriverReport" class="btn btn-success">
        <i class="bi bi-file-earmark-excel"></i> Export to Excel
    </a>
</div>

<!-- Report Table -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Rank</th>
                        <th>Driver</th>
                        <th>Total Trips</th>
                        <th>Completed</th>
                        <th>Completion Rate</th>
                        <th>Total Distance</th>
                        <th>Safety Score</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int rank = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (rank == 1)
                                {
                                    <i class="bi bi-trophy-fill text-warning fs-4"></i>
                                }
                                else if (rank == 2)
                                {
                                    <i class="bi bi-trophy-fill text-secondary fs-4"></i>
                                }
                                else if (rank == 3)
                                {
                                    <i class="bi bi-trophy-fill text-danger fs-4" style="color: #cd7f32 !important;"></i>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark">@rank</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded-circle p-2 me-2">
                                        <i class="bi bi-person-circle fs-5"></i>
                                    </div>
                                    <strong>@item.DriverName</strong>
                                </div>
                            </td>
                            <td>@item.TotalTrips</td>
                            <td>
                                <span class="badge bg-success">@item.CompletedTrips</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="progress flex-grow-1 me-2" style="height: 8px; width: 100px;">
                                        @{
                                            var rateColor = item.CompletionRate >= 80 ? "bg-success" :
                                            item.CompletionRate >= 60 ? "bg-warning" : "bg-danger";
                                        }
                                        <div class="progress-bar @rateColor" style="width: @item.CompletionRate%"></div>
                                    </div>
                                    <strong>@item.CompletionRate.ToString("0.0")%</strong>
                                </div>
                            </td>
                            <td>@item.TotalDistance.ToString("N0") km</td>
                            <td>
                                @{
                                    var scoreColor = item.SafetyScore >= 80 ? "success" :
                                    item.SafetyScore >= 60 ? "warning" : "danger";
                                }
                                <span class="badge bg-@scoreColor fs-6">@item.SafetyScore.ToString("0")</span>
                            </td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Reports
    </a>
</div>

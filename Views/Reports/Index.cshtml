@{
    ViewData["Title"] = "Operational Analytics & Reports";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-bar-chart"></i> Operational Analytics & Financial Reports</h4>
        <p class="text-muted mb-0">Data-driven decision making</p>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="opacity-75">Total Vehicles</h6>
                        <h2 class="mb-0">@ViewBag.TotalVehicles</h2>
                    </div>
                    <i class="bi bi-truck fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="opacity-75">Total Drivers</h6>
                        <h2 class="mb-0">@ViewBag.TotalDrivers</h2>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="opacity-75">Completed Trips</h6>
                        <h2 class="mb-0">@ViewBag.CompletedTrips</h2>
                    </div>
                    <i class="bi bi-check-circle fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="opacity-75">Total Revenue</h6>
                        <h2 class="mb-0">₹@ViewBag.TotalRevenue.ToString("N0")</h2>
                    </div>
                    <i class="bi bi-currency-rupee fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Financial Overview -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-cash-stack"></i> Financial Overview</h5>
            </div>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="border rounded p-3">
                            <h6 class="text-muted"><i class="bi bi-arrow-up-circle text-success"></i> Revenue</h6>
                            <h3 class="text-success">₹@ViewBag.TotalRevenue.ToString("N2")</h3>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded p-3">
                            <h6 class="text-muted"><i class="bi bi-arrow-down-circle text-danger"></i> Operational Costs</h6>
                            <h3 class="text-danger">₹@ViewBag.TotalOperationalCost.ToString("N2")</h3>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3">
                            <h6 class="text-muted"><i class="bi bi-fuel-pump text-info"></i> Fuel Cost</h6>
                            <h4>₹@ViewBag.TotalFuelCost.ToString("N2")</h4>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3">
                            <h6 class="text-muted"><i class="bi bi-tools text-warning"></i> Maintenance Cost</h6>
                            <h4>₹@ViewBag.TotalMaintenanceCost.ToString("N2")</h4>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3 @(ViewBag.NetProfit >= 0 ? "bg-success bg-opacity-10" : "bg-danger bg-opacity-10")">
                            <h6 class="text-muted"><i class="bi bi-graph-up"></i> Net Profit</h6>
                            <h4 class="@(ViewBag.NetProfit >= 0 ? "text-success" : "text-danger")">
                                ₹@ViewBag.NetProfit.ToString("N2")
                            </h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-download"></i> Export Reports</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-3">
                    <a asp-action="ExportVehicleReport" class="btn btn-outline-primary">
                        <i class="bi bi-file-earmark-excel"></i> Vehicle Performance Report
                    </a>
                    <a asp-action="ExportDriverReport" class="btn btn-outline-success">
                        <i class="bi bi-file-earmark-excel"></i> Driver Performance Report
                    </a>
                    <a asp-action="VehiclePerformance" class="btn btn-outline-info">
                        <i class="bi bi-eye"></i> View Vehicle Analytics
                    </a>
                    <a asp-action="DriverPerformance" class="btn btn-outline-warning">
                        <i class="bi bi-eye"></i> View Driver Analytics
                    </a>
                    <a asp-action="MonthlyReport" class="btn btn-outline-secondary">
                        <i class="bi bi-calendar-month"></i> Monthly Report
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Links -->
<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center py-4">
                <i class="bi bi-truck text-primary" style="font-size: 3rem;"></i>
                <h5 class="mt-3">Vehicle Performance</h5>
                <p class="text-muted small">Analyze vehicle efficiency, ROI, and operational costs</p>
                <a asp-action="VehiclePerformance" class="btn btn-primary">
                    View Report <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center py-4">
                <i class="bi bi-person-badge text-success" style="font-size: 3rem;"></i>
                <h5 class="mt-3">Driver Performance</h5>
                <p class="text-muted small">Track driver safety scores and completion rates</p>
                <a asp-action="DriverPerformance" class="btn btn-success">
                    View Report <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body text-center py-4">
                <i class="bi bi-calendar-check text-info" style="font-size: 3rem;"></i>
                <h5 class="mt-3">Monthly Report</h5>
                <p class="text-muted small">View monthly summaries and trends</p>
                <a asp-action="MonthlyReport" class="btn btn-info">
                    View Report <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

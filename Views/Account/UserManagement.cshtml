@model IEnumerable<FleetFlow.Models.ApplicationUser>
@{
    ViewData["Title"] = "User Management";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-people"></i> User Management</h4>
        <p class="text-muted mb-0">Manage system users and their roles</p>
    </div>
    <a asp-action="Register" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Register New User
    </a>
</div>

<!-- Users Table -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Registered On</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var isCurrentUser = User.Identity.Name == user.Email;

                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 rounded-circle p-2 me-3">
                                        <i class="bi bi-person-circle text-primary fs-5"></i>
                                    </div>
                                    <div>
                                        <strong>@user.FullName</strong>
                                        @if (isCurrentUser)
                                        {
                                            <span class="badge bg-success ms-2">You</span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @switch (user.Role)
                                {
                                    case FleetFlow.Models.UserRole.FleetManager:
                                        <span class="badge bg-danger"><i class="bi bi-shield-fill-check"></i> Fleet Manager</span>
                                        break;
                                    case FleetFlow.Models.UserRole.Dispatcher:
                                        <span class="badge bg-primary"><i class="bi bi-send"></i> Dispatcher</span>
                                        break;
                                    case FleetFlow.Models.UserRole.SafetyOfficer:
                                        <span class="badge bg-warning text-dark"><i class="bi bi-shield"></i> Safety Officer</span>
                                        break;
                                    case FleetFlow.Models.UserRole.FinancialAnalyst:
                                        <span class="badge bg-info"><i class="bi bi-graph-up"></i> Financial Analyst</span>
                                        break;
                                }
                            </td>
                            <td>
                                @{
                                    var createdDate = user.LockoutEnd?.DateTime ?? DateTime.Now;
                                }
                                <small class="text-muted">Member since registration</small>
                            </td>
                            <td class="text-center">
                                @if (!isCurrentUser)
                                {
                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                                onclick="return confirm('Are you sure you want to delete @user.FullName?')">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Role Permissions Info -->
<div class="card shadow-sm mt-4">
    <div class="card-header bg-white py-3">
        <h6 class="mb-0"><i class="bi bi-info-circle"></i> Role Permissions</h6>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <h6 class="text-danger"><i class="bi bi-shield-fill-check"></i> Fleet Manager</h6>
                <ul class="small">
                    <li>Full system access</li>
                    <li>User management</li>
                    <li>All CRUD operations</li>
                    <li>Financial reports</li>
                </ul>
            </div>
            <div class="col-md-6">
                <h6 class="text-primary"><i class="bi bi-send"></i> Dispatcher</h6>
                <ul class="small">
                    <li>Create and manage trips</li>
                    <li>View vehicles and drivers</li>
                    <li>Dispatch operations</li>
                    <li>Limited reports access</li>
                </ul>
            </div>
            <div class="col-md-6">
                <h6 class="text-warning"><i class="bi bi-shield"></i> Safety Officer</h6>
                <ul class="small">
                    <li>Driver management</li>
                    <li>License compliance tracking</li>
                    <li>Safety score updates</li>
                    <li>Driver performance reports</li>
                </ul>
            </div>
            <div class="col-md-6">
                <h6 class="text-info"><i class="bi bi-graph-up"></i> Financial Analyst</h6>
                <ul class="small">
                    <li>Read-only access</li>
                    <li>All financial reports</li>
                    <li>Export capabilities</li>
                    <li>Analytics dashboards</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@model FleetFlow.Models.Vehicle
@{
    ViewData["Title"] = "Edit Vehicle";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-warning py-3">
                <h5 class="mb-0">
                    <i class="bi bi-pencil"></i> Edit Vehicle: @Model.Name
                </h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @* IMPORTANT: Hidden fields for required properties *@
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="LicensePlate" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <div class="row g-4">
                        @* Vehicle Name *@
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label">
                                <i class="bi bi-car-front"></i> Vehicle Name/Model <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        @* License Plate (Read Only) *@
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="bi bi-card-text"></i> License Plate
                            </label>
                            <input type="text" class="form-control bg-light" value="@Model.LicensePlate" readonly disabled />
                            <small class="text-muted">License plate cannot be changed</small>
                        </div>

                        @* Vehicle Type *@
                        <div class="col-md-4">
                            <label asp-for="Type" class="form-label">
                                <i class="bi bi-tags"></i> Vehicle Type <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<FleetFlow.Models.VehicleType>()"></select>
                            <span asp-validation-for="Type" class="text-danger small"></span>
                        </div>

                        @* Max Capacity *@
                        <div class="col-md-4">
                            <label asp-for="MaxLoadCapacity" class="form-label">
                                <i class="bi bi-box"></i> Max Capacity (kg) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="MaxLoadCapacity" type="number" class="form-control" step="0.01" min="0" />
                            <span asp-validation-for="MaxLoadCapacity" class="text-danger small"></span>
                        </div>

                        @* Current Odometer *@
                        <div class="col-md-4">
                            <label asp-for="CurrentOdometer" class="form-label">
                                <i class="bi bi-speedometer"></i> Odometer (km) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="CurrentOdometer" type="number" class="form-control" step="0.01" min="0" />
                            <span asp-validation-for="CurrentOdometer" class="text-danger small"></span>
                        </div>

                        @* Status *@
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label">
                                <i class="bi bi-activity"></i> Status <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<FleetFlow.Models.VehicleStatus>()"></select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                        @* Region *@
                        <div class="col-md-4">
                            <label asp-for="Region" class="form-label">
                                <i class="bi bi-geo"></i> Region
                            </label>
                            <input asp-for="Region" class="form-control" placeholder="e.g., North, South" />
                            <span asp-validation-for="Region" class="text-danger small"></span>
                        </div>

                        @* Acquisition Cost *@
                        <div class="col-md-4">
                            <label asp-for="AcquisitionCost" class="form-label">
                                <i class="bi bi-currency-dollar"></i> Acquisition Cost
                            </label>
                            <input asp-for="AcquisitionCost" type="number" class="form-control" step="0.01" min="0" />
                            <span asp-validation-for="AcquisitionCost" class="text-danger small"></span>
                        </div>

                        @* Is Retired *@
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsRetired" class="form-check-input" id="isRetiredSwitch" />
                                <label asp-for="IsRetired" class="form-check-label" for="isRetiredSwitch">
                                    <strong>Mark as Retired</strong>
                                    <span class="text-muted">(Vehicle will be marked as Out of Service)</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    @* Vehicle Info Summary *@
                    <div class="alert alert-info">
                        <div class="row">
                            <div class="col-md-4">
                                <small class="text-muted">License Plate</small>
                                <br><strong>@Model.LicensePlate</strong>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted">Created On</small>
                                <br><strong>@Model.CreatedAt.ToString("dd MMM yyyy")</strong>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted">Current Status</small>
                                <br><strong>@Model.Status</strong>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-warning px-4">
                            <i class="bi bi-save"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Auto-change status when retired is checked
        document.getElementById('isRetiredSwitch').addEventListener('change', function() {
            var statusSelect = document.getElementById('Status');
            if (this.checked) {
                statusSelect.value = '3'; // OutOfService
            } else {
                statusSelect.value = '0'; // Available
            }
        });
    </script>
}

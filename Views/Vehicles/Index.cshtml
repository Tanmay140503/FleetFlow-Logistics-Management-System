@model IEnumerable<FleetFlow.Models.Vehicle>
@{
    ViewData["Title"] = "Vehicle Registry";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-bus-front"></i> Vehicle Registry</h4>
        <p class="text-muted mb-0">Manage your fleet assets</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Vehicle
    </a>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h6 class="card-title opacity-75">Total Vehicles</h6>
                <h3>@Model.Count()</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h6 class="card-title opacity-75">Available</h6>
                <h3>@Model.Count(v => v.Status == FleetFlow.Models.VehicleStatus.Available)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <h6 class="card-title opacity-75">On Trip</h6>
                <h3>@Model.Count(v => v.Status == FleetFlow.Models.VehicleStatus.OnTrip)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark">
            <div class="card-body">
                <h6 class="card-title opacity-75">In Maintenance</h6>
                <h3>@Model.Count(v => v.Status == FleetFlow.Models.VehicleStatus.InShop)</h3>
            </div>
        </div>
    </div>
</div>

<!-- Vehicles Table -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Vehicle</th>
                        <th>License Plate</th>
                        <th>Type</th>
                        <th>Capacity</th>
                        <th>Odometer</th>
                        <th>Region</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vehicle in Model)
                    {
                        <tr class="@(vehicle.IsRetired ? "table-secondary" : "")">
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded p-2 me-3">
                                        @switch (vehicle.Type)
                                        {
                                            case FleetFlow.Models.VehicleType.Truck:
                                                <i class="bi bi-truck text-primary fs-5"></i>
                                                break;
                                            case FleetFlow.Models.VehicleType.Van:
                                                <i class="bi bi-bus-front text-info fs-5"></i>
                                                break;
                                            case FleetFlow.Models.VehicleType.Bike:
                                                <i class="bi bi-bicycle text-success fs-5"></i>
                                                break;
                                        }
                                    </div>
                                    <div>
                                        <strong>@vehicle.Name</strong>
                                        @if (vehicle.IsRetired)
                                        {
                                            <br>
                                    
                                            <span class="badge bg-secondary">Retired</span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td><code class="bg-light px-2 py-1 rounded">@vehicle.LicensePlate</code></td>
                            <td>@vehicle.Type</td>
                            <td><strong>@vehicle.MaxLoadCapacity.ToString("N0")</strong> kg</td>
                            <td>@vehicle.CurrentOdometer.ToString("N0") km</td>
                            <td>@vehicle.Region</td>
                            <td>
                                @switch (vehicle.Status)
                                {
                                    case FleetFlow.Models.VehicleStatus.Available:
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Available</span>
                                        break;
                                    case FleetFlow.Models.VehicleStatus.OnTrip:
                                        <span class="badge bg-primary"><i class="bi bi-geo-alt"></i> On Trip</span>
                                        break;
                                    case FleetFlow.Models.VehicleStatus.InShop:
                                        <span class="badge bg-warning text-dark"><i class="bi bi-tools"></i> In Shop</span>
                                        break;
                                    case FleetFlow.Models.VehicleStatus.OutOfService:
                                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Out of Service</span>
                                        break;
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@vehicle.Id"
                                       class="btn btn-outline-primary" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@vehicle.Id"
                                       class="btn btn-outline-warning" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ToggleRetire" asp-route-id="@vehicle.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-outline-@(vehicle.IsRetired ? "success" : "danger")"
                                                title="@(vehicle.IsRetired ? "Reactivate" : "Retire")"
                                                onclick="return confirm('Are you sure you want to @(vehicle.IsRetired ? "reactivate" : "retire") this vehicle?')">
                                            <i class="bi bi-@(vehicle.IsRetired ? "arrow-clockwise" : "archive")"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

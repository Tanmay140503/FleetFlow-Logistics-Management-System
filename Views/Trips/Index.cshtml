@model IEnumerable<FleetFlow.Models.Trip>
@{
    ViewData["Title"] = "Trip Management";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-geo-alt"></i> Trip Dispatcher & Management</h4>
        <p class="text-muted mb-0">Create and manage delivery trips</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Create New Trip
    </a>
</div>

<!-- Status Filter Tabs -->
<ul class="nav nav-pills mb-4">
    <li class="nav-item">
        <a class="nav-link @(ViewBag.CurrentFilter == null ? "active" : "")" asp-action="Index">
            All Trips <span class="badge bg-light text-dark ms-1">@Model.Count()</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewBag.CurrentFilter?.ToString() == "Draft" ? "active" : "")"
           asp-action="Index" asp-route-status="Draft">
            <i class="bi bi-file-earmark"></i> Draft
            <span class="badge bg-secondary ms-1">@Model.Count(t => t.Status == FleetFlow.Models.TripStatus.Draft)</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewBag.CurrentFilter?.ToString() == "Dispatched" ? "active" : "")"
           asp-action="Index" asp-route-status="Dispatched">
            <i class="bi bi-send"></i> Dispatched
            <span class="badge bg-primary ms-1">@Model.Count(t => t.Status == FleetFlow.Models.TripStatus.Dispatched)</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewBag.CurrentFilter?.ToString() == "Completed" ? "active" : "")"
           asp-action="Index" asp-route-status="Completed">
            <i class="bi bi-check-circle"></i> Completed
            <span class="badge bg-success ms-1">@Model.Count(t => t.Status == FleetFlow.Models.TripStatus.Completed)</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewBag.CurrentFilter?.ToString() == "Cancelled" ? "active" : "")"
           asp-action="Index" asp-route-status="Cancelled">
            <i class="bi bi-x-circle"></i> Cancelled
            <span class="badge bg-danger ms-1">@Model.Count(t => t.Status == FleetFlow.Models.TripStatus.Cancelled)</span>
        </a>
    </li>
</ul>

<!-- Trips Table -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Trip Code</th>
                        <th>Vehicle</th>
                        <th>Driver</th>
                        <th>Route</th>
                        <th>Cargo</th>
                        <th>Created</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var trip in Model)
                        {
                            <tr>
                                <td>
                                    <code class="bg-light px-2 py-1 rounded">@trip.TripCode</code>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @switch (trip.Vehicle.Type)
                                        {
                                            case FleetFlow.Models.VehicleType.Truck:
                                                <i class="bi bi-truck text-primary me-2"></i>
                                                break;
                                            case FleetFlow.Models.VehicleType.Van:
                                                <i class="bi bi-bus-front text-info me-2"></i>
                                                break;
                                            case FleetFlow.Models.VehicleType.Bike:
                                                <i class="bi bi-bicycle text-success me-2"></i>
                                                break;
                                        }
                                        <div>
                                            <strong>@trip.Vehicle.Name</strong>
                                            <br><small class="text-muted">@trip.Vehicle.LicensePlate</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <i class="bi bi-person-circle me-1"></i> @trip.Driver.Name
                                </td>
                                <td>
                                    <small>
                                        <i class="bi bi-geo-alt text-success"></i> @trip.OriginAddress
                                        <br>
                                        <i class="bi bi-arrow-down text-muted"></i>
                                        <br>
                                        <i class="bi bi-geo-alt-fill text-danger"></i> @trip.DestinationAddress
                                    </small>
                                </td>
                                <td>
                                    <strong>@trip.CargoWeight kg</strong>
                                    @if (!string.IsNullOrEmpty(trip.CargoDescription))
                                    {
                                        <br>
                            
                                        <small class="text-muted">@trip.CargoDescription</small>
                                    }
                                </td>
                                <td>
                                    @trip.CreatedAt.ToString("dd MMM yyyy")
                                    <br><small class="text-muted">@trip.CreatedAt.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    @switch (trip.Status)
                                    {
                                        case FleetFlow.Models.TripStatus.Draft:
                                            <span class="badge bg-secondary"><i class="bi bi-file-earmark"></i> Draft</span>
                                            break;
                                        case FleetFlow.Models.TripStatus.Dispatched:
                                            <span class="badge bg-primary"><i class="bi bi-send"></i> Dispatched</span>
                                            break;
                                        case FleetFlow.Models.TripStatus.Completed:
                                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Completed</span>
                                            break;
                                        case FleetFlow.Models.TripStatus.Cancelled:
                                            <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Cancelled</span>
                                            break;
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        @if (trip.Status == FleetFlow.Models.TripStatus.Draft)
                                        {
                                            <form asp-action="Dispatch" asp-route-id="@trip.Id" method="post" style="display:inline;">
                                                <button type="submit" class="btn btn-primary" title="Dispatch"
                                                        onclick="return confirm('Dispatch this trip?')">
                                                    <i class="bi bi-send"></i> Dispatch
                                                </button>
                                            </form>
                                        }
                                        @if (trip.Status == FleetFlow.Models.TripStatus.Dispatched)
                                        {
                                            <a asp-action="Complete" asp-route-id="@trip.Id" class="btn btn-success" title="Complete">
                                                <i class="bi bi-check-circle"></i> Complete
                                            </a>
                                        }
                                        @if (trip.Status != FleetFlow.Models.TripStatus.Completed && trip.Status != FleetFlow.Models.TripStatus.Cancelled)
                                        {
                                            <button type="button" class="btn btn-outline-danger"
                                                    data-bs-toggle="modal" data-bs-target="#cancelModal-@trip.Id" title="Cancel">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                        <a asp-action="Details" asp-route-id="@trip.Id" class="btn btn-outline-secondary" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>

                                    <!-- Cancel Modal -->
                                    <div class="modal fade" id="cancelModal-@trip.Id" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Cancel Trip: @trip.TripCode</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <form asp-action="Cancel" asp-route-id="@trip.Id" method="post">
                                                    <div class="modal-body">
                                                        <div class="mb-3">
                                                            <label class="form-label">Cancellation Reason <span class="text-danger">*</span></label>
                                                            <textarea name="reason" class="form-control" rows="3" required
                                                              placeholder="Please provide a reason for cancellation..."></textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                        <button type="submit" class="btn btn-danger">
                                                            <i class="bi bi-x-circle"></i> Cancel Trip
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                                <p class="text-muted mt-3">No trips found</p>
                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="bi bi-plus-circle"></i> Create First Trip
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@model FleetFlow.Models.Trip
@{
    ViewData["Title"] = "Complete Trip";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white py-3">
                <h5 class="mb-0">
                    <i class="bi bi-check-circle"></i> Complete Trip: @Model.TripCode
                </h5>
            </div>
            <div class="card-body p-4">

                <!-- Trip Summary -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="text-muted mb-3">Trip Details</h6>
                                <p class="mb-2">
                                    <strong>Vehicle:</strong> @Model.Vehicle.Name (@Model.Vehicle.LicensePlate)
                                </p>
                                <p class="mb-2">
                                    <strong>Driver:</strong> @Model.Driver.Name
                                </p>
                                <p class="mb-2">
                                    <strong>Cargo:</strong> @Model.CargoWeight kg
                                </p>
                                <p class="mb-0">
                                    <strong>Dispatched:</strong> @Model.DispatchedAt?.ToString("dd MMM yyyy hh:mm tt")
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="text-muted mb-3">Route</h6>
                                <p class="mb-2">
                                    <i class="bi bi-geo-alt text-success"></i> <strong>From:</strong><br>
                                    @Model.OriginAddress
                                </p>
                                <p class="mb-0">
                                    <i class="bi bi-geo-alt-fill text-danger"></i> <strong>To:</strong><br>
                                    @Model.DestinationAddress
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <form asp-action="Complete" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="row g-4">
                        <!-- End Odometer -->
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="bi bi-speedometer"></i> End Odometer Reading (km) <span class="text-danger">*</span>
                            </label>
                            <input type="number" name="endOdometer" class="form-control" step="0.01"
                                   min="@Model.StartOdometer" value="@Model.StartOdometer" required />
                            <small class="text-muted">Start odometer: @Model.StartOdometer.ToString("N0") km</small>
                        </div>

                        <!-- Actual Revenue -->
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="bi bi-currency-rupee"></i> Actual Revenue
                            </label>
                            <input type="number" name="actualRevenue" class="form-control" step="0.01"
                                   value="@Model.Revenue" placeholder="0.00" />
                            @if (Model.Revenue.HasValue)
                            {
                                <small class="text-muted">Expected: $@Model.Revenue.Value.ToString("N2")</small>
                            }
                        </div>

                        <!-- Notes -->
                        <div class="col-12">
                            <label class="form-label">
                                <i class="bi bi-journal-text"></i> Completion Notes
                            </label>
                            <textarea name="notes" class="form-control" rows="3"
                                      placeholder="Any additional notes about this trip...">@Model.Notes</textarea>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        <strong>What happens when you complete this trip:</strong>
                        <ul class="mb-0 mt-2 small">
                            <li>Vehicle status will change to "Available"</li>
                            <li>Vehicle odometer will be updated to the end reading</li>
                            <li>Driver status will change to "Off Duty"</li>
                            <li>Driver's completed trips count will increase</li>
                        </ul>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-success px-4">
                            <i class="bi bi-check-circle"></i> Mark as Completed
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

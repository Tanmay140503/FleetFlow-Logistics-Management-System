@model IEnumerable<FleetFlow.Models.Driver>
@{
    ViewData["Title"] = "Driver Management";
    var expiringLicenses = ViewBag.ExpiringLicenses as List<FleetFlow.Models.Driver>;
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-person-badge"></i> Driver Performance & Safety Profiles</h4>
        <p class="text-muted mb-0">Manage drivers and track compliance</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Driver
    </a>
</div>

<!-- License Expiry Alert -->
@if (expiringLicenses != null && expiringLicenses.Any())
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <h6 class="alert-heading"><i class="bi bi-exclamation-triangle"></i> License Expiry Warning!</h6>
        <p class="mb-0">
            The following drivers have licenses expiring within 30 days:
            <strong>@string.Join(", ", expiringLicenses.Select(d => d.Name))</strong>
        </p>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="opacity-75">Total Drivers</h6>
                        <h3 class="mb-0">@Model.Count()</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="opacity-75">On Duty</h6>
                        <h3 class="mb-0">@Model.Count(d => d.Status == FleetFlow.Models.DriverStatus.OnDuty)</h3>
                    </div>
                    <i class="bi bi-person-check fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-secondary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="opacity-75">Off Duty</h6>
                        <h3 class="mb-0">@Model.Count(d => d.Status == FleetFlow.Models.DriverStatus.OffDuty)</h3>
                    </div>
                    <i class="bi bi-person-dash fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-danger text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="opacity-75">Suspended</h6>
                        <h3 class="mb-0">@Model.Count(d => d.Status == FleetFlow.Models.DriverStatus.Suspended)</h3>
                    </div>
                    <i class="bi bi-person-x fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Drivers Table -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Driver</th>
                        <th>License</th>
                        <th>License Expiry</th>
                        <th>Category</th>
                        <th>Safety Score</th>
                        <th>Trips Completed</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var driver in Model)
                    {
                        var isLicenseExpired = driver.LicenseExpiry <= DateTime.Now;
                        var isLicenseExpiring = driver.LicenseExpiry <= DateTime.Now.AddDays(30) && !isLicenseExpired;

                        <tr class="@(driver.Status == FleetFlow.Models.DriverStatus.Suspended ? "table-danger" : "")">
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded-circle p-2 me-3">
                                        <i class="bi bi-person-circle fs-4 text-secondary"></i>
                                    </div>
                                    <div>
                                        <strong>@driver.Name</strong>
                                        <br><small class="text-muted">@driver.Email</small>
                                    </div>
                                </div>
                            </td>
                            <td><code>@driver.LicenseNumber</code></td>
                            <td>
                                @if (isLicenseExpired)
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-x-circle"></i> Expired
                                    </span>
                                    <br>

                                    <small class="text-danger">@driver.LicenseExpiry.ToString("dd MMM yyyy")</small>
                                }
                                else if (isLicenseExpiring)
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-exclamation-triangle"></i> Expiring Soon
                                    </span>
                                    <br>

                                    <small class="text-warning">@driver.LicenseExpiry.ToString("dd MMM yyyy")</small>
                                }
                                else
                                {
                                    <span class="text-success">
                                        <i class="bi bi-check-circle"></i> Valid
                                    </span>
                                    <br>

                                    <small>@driver.LicenseExpiry.ToString("dd MMM yyyy")</small>
                                }
                            </td>
                            <td>@driver.LicenseCategory</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="progress flex-grow-1 me-2" style="height: 8px; width: 80px;">
                                        @{
                                            var scoreColor = driver.SafetyScore >= 80 ? "bg-success" :
                                            driver.SafetyScore >= 60 ? "bg-warning" : "bg-danger";
                                        }
                                        <div class="progress-bar @scoreColor" style="width: @driver.SafetyScore%"></div>
                                    </div>
                                    <strong>@driver.SafetyScore.ToString("0")</strong>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark">
                                    @driver.TotalTripsCompleted trips
                                </span>
                            </td>
                            <td>
                                @switch (driver.Status)
                                {
                                    case FleetFlow.Models.DriverStatus.OnDuty:
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> On Duty</span>
                                        break;
                                    case FleetFlow.Models.DriverStatus.OffDuty:
                                        <span class="badge bg-secondary"><i class="bi bi-moon"></i> Off Duty</span>
                                        break;
                                    case FleetFlow.Models.DriverStatus.Suspended:
                                        <span class="badge bg-danger"><i class="bi bi-slash-circle"></i> Suspended</span>
                                        break;
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@driver.Id"
                                       class="btn btn-outline-primary" title="View Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@driver.Id"
                                       class="btn btn-outline-warning" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (driver.Status == FleetFlow.Models.DriverStatus.Suspended)
                                    {
                                        <form asp-action="Reactivate" asp-route-id="@driver.Id" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-outline-success" title="Reactivate"
                                                    onclick="return confirm('Reactivate this driver?')">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-outline-danger" title="Suspend"
                                                data-bs-toggle="modal" data-bs-target="#suspendModal-@driver.Id">
                                            <i class="bi bi-slash-circle"></i>
                                        </button>
                                    }
                                </div>

                                <!-- Suspend Modal -->
                                <div class="modal fade" id="suspendModal-@driver.Id" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Suspend Driver: @driver.Name</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form asp-action="Suspend" asp-route-id="@driver.Id" method="post">
                                                <div class="modal-body">
                                                    <div class="mb-3">
                                                        <label class="form-label">Suspension Reason <span class="text-danger">*</span></label>
                                                        <textarea name="reason" class="form-control" rows="3" required
                                                              placeholder="Enter reason for suspension..."></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-danger">
                                                        <i class="bi bi-slash-circle"></i> Suspend Driver
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

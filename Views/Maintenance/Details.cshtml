@model FleetFlow.Models.MaintenanceLog
@{
    ViewData["Title"] = "Maintenance Details";
    var maintenanceHistory = ViewBag.VehicleMaintenanceHistory as List<FleetFlow.Models.MaintenanceLog>;
    decimal totalVehicleCost = ViewBag.TotalVehicleMaintenanceCost ?? 0;
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Maintenance</a></li>
        <li class="breadcrumb-item active">@Model.ServiceType</li>
    </ol>
</nav>

<div class="row g-4">
    <!-- Main Details Card -->
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header py-3 @(Model.IsCompleted ? "bg-success text-white" : "bg-warning")">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-tools"></i> @Model.ServiceType
                    </h5>
                    @if (Model.IsCompleted)
                    {
                        <span class="badge bg-light text-success">
                            <i class="bi bi-check-circle-fill"></i> Completed
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-dark">
                            <i class="bi bi-hourglass-split"></i> In Progress
                        </span>
                    }
                </div>
            </div>
            <div class="card-body">
                <!-- Vehicle Info -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 rounded-circle p-3 me-3">
                                @switch (Model.Vehicle?.Type)
                                {
                                    case FleetFlow.Models.VehicleType.Truck:
                                        <i class="bi bi-truck text-primary fs-4"></i>
                                        break;
                                    case FleetFlow.Models.VehicleType.Van:
                                        <i class="bi bi-bus-front text-info fs-4"></i>
                                        break;
                                    case FleetFlow.Models.VehicleType.Bike:
                                        <i class="bi bi-bicycle text-success fs-4"></i>
                                        break;
                                    default:
                                        <i class="bi bi-truck text-primary fs-4"></i>
                                        break;
                                }
                            </div>
                            <div>
                                <h5 class="mb-1">@Model.Vehicle?.Name</h5>
                                <code class="bg-light px-2 py-1 rounded">@Model.Vehicle?.LicensePlate</code>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <small class="text-muted d-block">Current Vehicle Status</small>
                        @switch (Model.Vehicle?.Status)
                        {
                            case FleetFlow.Models.VehicleStatus.Available:
                                <span class="badge bg-success fs-6">Available</span>
                                break;
                            case FleetFlow.Models.VehicleStatus.OnTrip:
                                <span class="badge bg-primary fs-6">On Trip</span>
                                break;
                            case FleetFlow.Models.VehicleStatus.InShop:
                                <span class="badge bg-warning text-dark fs-6">In Shop</span>
                                break;
                            case FleetFlow.Models.VehicleStatus.OutOfService:
                                <span class="badge bg-danger fs-6">Out of Service</span>
                                break;
                        }
                    </div>
                </div>

                <hr>

                <!-- Service Details -->
                <div class="row g-4">
                    <div class="col-md-3">
                        <div class="text-center p-3 bg-light rounded">
                            <i class="bi bi-currency-rupee text-danger fs-2"></i>
                            <h6 class="text-muted mt-2 mb-1">Cost</h6>
                            <h4 class="text-danger mb-0">₹@Model.Cost.ToString("N2")</h4>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-center p-3 bg-light rounded">
                            <i class="bi bi-calendar text-primary fs-2"></i>
                            <h6 class="text-muted mt-2 mb-1">Service Date</h6>
                            <h5 class="mb-0">@Model.ServiceDate.ToString("dd MMM yyyy")</h5>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-center p-3 bg-light rounded">
                            <i class="bi bi-speedometer text-info fs-2"></i>
                            <h6 class="text-muted mt-2 mb-1">Odometer</h6>
                            <h5 class="mb-0">@Model.OdometerAtService.ToString("N0") km</h5>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-center p-3 bg-light rounded">
                            @if (Model.IsCompleted && Model.CompletedDate.HasValue)
                            {
                                <i class="bi bi-check-circle text-success fs-2"></i>
                                <h6 class="text-muted mt-2 mb-1">Completed On</h6>
                                <h5 class="mb-0">@Model.CompletedDate.Value.ToString("dd MMM")</h5>
                            }
                            else
                            {
                                <i class="bi bi-hourglass-split text-warning fs-2"></i>
                                <h6 class="text-muted mt-2 mb-1">Status</h6>
                                <h5 class="mb-0 text-warning">Pending</h5>
                            }
                        </div>
                    </div>
                </div>

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mt-4">
                        <h6 class="text-muted"><i class="bi bi-card-text"></i> Description</h6>
                        <div class="p-3 bg-light rounded">
                            @Model.Description
                        </div>
                    </div>
                }

                <!-- Workshop Info -->
                @if (!string.IsNullOrEmpty(Model.PerformedBy))
                {
                    <div class="mt-4">
                        <h6 class="text-muted"><i class="bi bi-building"></i> Performed By</h6>
                        <p class="mb-0">
                            <strong>@Model.PerformedBy</strong>
                        </p>
                    </div>
                }

                <hr class="my-4">

                <!-- Action Buttons -->
                <div class="d-flex justify-content-between flex-wrap gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                    <div class="d-flex gap-2 flex-wrap">
                        @if (!Model.IsCompleted)
                        {
                            <form asp-action="MarkComplete" asp-route-id="@Model.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-success"
                                        onclick="return confirm('Mark this maintenance as complete?')">
                                    <i class="bi bi-check-circle"></i> Mark Complete
                                </button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Reopen" asp-route-id="@Model.Id" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-warning"
                                        onclick="return confirm('Reopen this maintenance? Vehicle will be set to In Shop.')">
                                    <i class="bi bi-arrow-counterclockwise"></i> Reopen
                                </button>
                            </form>
                        }
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Vehicle Maintenance History -->
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history"></i> Other Maintenance for @Model.Vehicle?.Name
                </h5>
            </div>
            <div class="card-body p-0">
                @if (maintenanceHistory != null && maintenanceHistory.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Service Type</th>
                                    <th>Date</th>
                                    <th>Cost</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in maintenanceHistory)
                                {
                                    <tr>
                                        <td><strong>@log.ServiceType</strong></td>
                                        <td>@log.ServiceDate.ToString("dd MMM yyyy")</td>
                                        <td>$@log.Cost.ToString("N2")</td>
                                        <td>
                                            @if (log.IsCompleted)
                                            {
                                                <span class="badge bg-success">Completed</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">In Progress</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@log.Id" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-inbox"></i> No other maintenance records for this vehicle
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Sidebar -->
    <div class="col-lg-4">
        <!-- Quick Stats -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0"><i class="bi bi-graph-up"></i> Vehicle Stats</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted">Total Maintenance Cost</span>
                    <strong class="text-danger">₹@totalVehicleCost.ToString("N2")</strong>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted">Current Odometer</span>
                    <strong>@Model.Vehicle?.CurrentOdometer.ToString("N0") km</strong>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted">Vehicle Type</span>
                    <strong>@Model.Vehicle?.Type</strong>
                </div>
            </div>
        </div>

        <!-- Timeline -->
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0"><i class="bi bi-clock"></i> Timeline</h6>
            </div>
            <div class="card-body">
                <div class="timeline">
                    <!-- Created -->
                    <div class="d-flex mb-3">
                        <div class="flex-shrink-0">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
                                 style="width: 35px; height: 35px;">
                                <i class="bi bi-plus-lg"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <strong>Service Scheduled</strong>
                            <br><small class="text-muted">@Model.ServiceDate.ToString("dd MMM yyyy")</small>
                        </div>
                    </div>

                    <!-- Completed -->
                    @if (Model.IsCompleted && Model.CompletedDate.HasValue)
                    {
                        <div class="d-flex mb-3">
                            <div class="flex-shrink-0">
                                <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center"
                                     style="width: 35px; height: 35px;">
                                    <i class="bi bi-check-lg"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <strong>Completed</strong>
                                <br><small class="text-muted">@Model.CompletedDate.Value.ToString("dd MMM yyyy hh:mm tt")</small>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex mb-3">
                            <div class="flex-shrink-0">
                                <div class="bg-warning rounded-circle d-flex align-items-center justify-content-center"
                                     style="width: 35px; height: 35px;">
                                    <i class="bi bi-hourglass-split text-dark"></i>
                                </div>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <strong>In Progress</strong>
                                <br><small class="text-muted">Awaiting completion</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0"><i class="bi bi-lightning"></i> Quick Actions</h6>
            </div>
            <div class="card-body d-grid gap-2">
                <a asp-controller="Vehicles" asp-action="Details" asp-route-id="@Model.VehicleId" class="btn btn-outline-primary">
                    <i class="bi bi-truck"></i> View Vehicle
                </a>
                <a asp-action="Create" asp-route-vehicleId="@Model.VehicleId" class="btn btn-outline-success">
                    <i class="bi bi-plus-circle"></i> Add Another Service
                </a>
                <a asp-controller="FuelLogs" asp-action="Create" asp-route-vehicleId="@Model.VehicleId" class="btn btn-outline-info">
                    <i class="bi bi-fuel-pump"></i> Add Fuel Log
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete Maintenance Log</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this maintenance log?</p>
                <div class="alert alert-secondary">
                    <strong>Service:</strong> @Model.ServiceType<br>
                    <strong>Vehicle:</strong> @Model.Vehicle?.Name<br>
                    <strong>Cost:</strong> $@Model.Cost.ToString("N2")<br>
                    <strong>Date:</strong> @Model.ServiceDate.ToString("dd MMM yyyy")
                </div>
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i> This action cannot be undone.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:inline;">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>